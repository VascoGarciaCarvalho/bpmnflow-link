{
  "name": "bpmnflow-link",
  "version": "1.0.0",
  "description": "Connects BPMN diagrams to real technological execution",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch server.ts\" \"vite\"",
    "dev:server": "tsx watch server.ts",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node --import tsx/esm server.ts"
  },
  "dependencies": {
    "express": "^4",
    "bpmn-moddle": "^8",
    "nodemailer": "^6"
  },
  "devDependencies": {
    "typescript": "^5",
    "tsx": "^4",
    "vite": "^5",
    "@vitejs/plugin-react": "^4",
    "react": "^18",
    "react-dom": "^18",
    "@types/node": "^20",
    "@types/express": "^4",
    "@types/nodemailer": "^6",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^8"
  }
}
